{
  "name": "fantasy-novel-workshop",
  "version": "1.0.0",
  "description": "FNW - 纯本地玄幻小说写作系统",
  "main": "out/main/index.js",
  "author": "FNW Team",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --win --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@uiw/react-md-editor": "^4.0.4",
    "antd": "^5.15.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.1.1",
    "electron-store": "^8.2.0",
    "isomorphic-git": "^1.25.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "sql.js": "^1.14.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.fnw.fantasynovelworkshop",
    "productName": "Fantasy Novel Workshop",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
